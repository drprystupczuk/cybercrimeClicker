# .gitignore for Visual Studio / .NET Framework projects
# Recommended for projects targeting .NET Framework 4.0 (Visual Studio)

# User-specific files
*.suo
*.user
*.userosscache
*.rsuser
*.sln.docstates
*.VC.db
*.VC.VC.opendb
*.pidb

# Build results
[Bb]in/
[Oo]bj/

# Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons
*.cache
*.ilk
*.meta
*.obj
*.pch
*.pdb
*.ipch
*.tlog
*.log
*.vspscc
*.vssscc

# NuGet
*.nupkg
packages/
.nuget/
project.lock.json
project.fragment.lock.json

# Visual Studio Code workspace settings
.vscode/

# Visual Studio workspace
.vs/

# Publish outputs
publish/
PublishOutput/

# Test results
TestResults/
*.trx

# Rider / JetBrains
.idea/
*.sln.iml
*.iml

# Resharper
_ReSharper*/
*._ReSharper.*
*.DotSettings.user

# Node
node_modules/

# Logs
*.log

# Database files
*.mdf
*.ldf
*.ndf
*.db
*.sql

# Backup & temporary
*~
~$*
*.tmp
*.temp
*.bak
*.backup

# OS generated files
Thumbs.db
Desktop.ini

# Coverage
coverage/
*.coverage
*.coveragexml

# Others
*.dbmdl
*.suo
*.user

# Ignore object/temporary files generated in project obj folders (multiple platforms)
**/obj/**
**/bin/**

# End of file
